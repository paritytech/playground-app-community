# Sentry DSN override. The default DSN is hardcoded in src/sentry.ts so this
# is only needed to (a) point at a different Sentry project, or (b) set it
# empty (VITE_SENTRY_DSN=) to disable Sentry locally.
# VITE_SENTRY_DSN=

# Point the frontend at a different cdm package for the registry contract.
# Production default = @w3s/playground-registry. When iterating on a new
# contract version that has only been deployed to @staging, set this to
# @staging/playground-registry so the runtime resolves to the new ABI.
# Leave commented in production deploys.
# VITE_PLAYGROUND_REGISTRY_PACKAGE=@staging/playground-registry
