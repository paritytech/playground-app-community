{
  "name": "Polkadot Playground",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "playground:description": "A Web app for exploring & Modding example websites in the Polkadot ecosystem.",
  "playground:tag": "social",
  "playground:icon": "./assets/icon.png",
  "scripts": {
    "dev": "vite --host",
    "build:frontend": "tsc -b && vite build",
    "build:contracts": "cdm build",
    "typecheck": "tsc -b",
    "deploy": "cdm deploy -n paseo",
    "preview": "vite preview",
    "deploy:frontend": "MNEMONIC=$(node -e \"process.stdout.write(require(require('os').homedir()+'/.cdm/accounts.json').paseo.mnemonic)\") npx bulletin-deploy --env paseo-next-v2 ./dist playgroundtest.dot",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:contract": "vitest run --project=contract",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint:license": "./scripts/check-license-headers.sh"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@novasamatech/host-api": "0.8.6",
    "@novasamatech/host-api-wrapper": "0.8.6",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-cloud-storage": "^0.6.0",
    "@parity/product-sdk-chain-client": "^0.7.0",
    "@parity/product-sdk-contracts": "^0.7.3",
    "@parity/product-sdk-descriptors": "^0.6.0",
    "@parity/product-sdk-host": "^0.8.0",
    "@parity/product-sdk-keys": "^0.3.6",
    "@parity/product-sdk-logger": "^0.1.1",
    "@parity/product-sdk-signer": "^0.6.3",
    "@parity/product-sdk-utils": "^0.1.1",
    "@polkadot-api/substrate-bindings": "^0.20.2",
    "@polkadot-labs/hdkd-helpers": "^0.0.30",
    "@scure/sr25519": "^2.2.0",
    "@sentry/react": "^10.53.0",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.4.2",
    "lucide-react": "^0.469.0",
    "marked": "^17.0.6",
    "polkadot-api": "^2.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.1.1",
    "scale-ts": "^1.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@parity/bulletin-sdk": "^0.3.0",
    "@parity/host-api-test-sdk": "^0.9.1",
    "@parity/product-sdk-tx": "^0.2.10",
    "@playwright/test": "^1.60.0",
    "@polkadot-api/sdk-ink": "^0.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "_comment_overrides": "@polkadot-api/json-rpc-provider: upstream packaging bug workaround (mirrors product-sdk's monorepo). @novasamatech/host-api*: pinned to exact 0.8.6 — bumped from 0.8.3 to try latest stable. Prior bisection against Polkadot Desktop 0.4.1 (which ships 0.8.0) showed 0.8.0/0.8.2/0.8.3 handshake cleanly while 0.8.4 silently drops host_handshake_request → transport.isReady() never resolves → every host call throws 'Polkadot host is not ready', chain providers go dead with misleading 'Host doesn't support it' log. Verify handshake in Desktop before merging; if broken, revert to 0.8.3.",
    "overrides": {
      "@polkadot-api/json-rpc-provider": "^0.2.0",
      "@novasamatech/host-api": "0.8.6",
      "@novasamatech/host-api-wrapper": "0.8.6"
    }
  }
}
